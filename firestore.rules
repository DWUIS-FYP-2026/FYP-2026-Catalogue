rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isSupervisor() {
      return signedIn()
        && exists(/databases/$(database)/documents/supervisors/$(request.auth.uid))
        && get(/databases/$(database)/documents/supervisors/$(request.auth.uid)).data.active == true;
    }

    // Public register: only information appropriate for public publication belongs here.
    match /projects/{projectId} {
      allow read: if true;
      allow create, update: if isSupervisor();
      allow delete: if false;
    }

    // A user may only read their own supervisor profile. Profiles are created
    // by the Firebase administrator in the console, not by the public website.
    match /supervisors/{supervisorId} {
      allow get: if signedIn() && request.auth.uid == supervisorId;
      allow list, create, update, delete: if false;
    }

    // The audit log is available to supervisors only. Entries are append-only.
    match /project_audit/{entryId} {
      allow read, create: if isSupervisor();
      allow update, delete: if false;
    }
  }
}
